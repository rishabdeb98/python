class Book:
    def __init__(self,title,author,pages,price,publisher):
        self.title=title
        self.author=author
        self.pages=pages
        self.price=price
        self.publisher=publisher
#creating object
x1=Book("Basics Mathematics","R.D Sharma","256","451","ARK Publication")
print(x1.title)
print(x1.author)
print(x1.pages)
